// Deploy to the same project as VITE_FIREBASE_PROJECT_ID (local .env / CI secrets):
//   npm run deploy:firestore-rules
// If the console still shows permission-denied for public events, the rules below are not
// deployed to that project yet (default Firestore rules deny all reads).

rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Users can read and write only their own profile
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    match /matches/{matchId} {
      // Public matches (home page lists) OR any match for signed-in users (private rooms, etc.)
      allow read: if resource.data.isPublic == true || request.auth != null;

      // Authenticated users can create a match they own
      allow create: if request.auth != null
                    && request.resource.data.creatorId == request.auth.uid;

      // Creator, admins, or refs (existing or being added) can update
      allow update: if request.auth != null && (
                      request.auth.uid == resource.data.creatorId
                      || request.auth.uid in resource.data.adminIds
                      || request.auth.uid in resource.data.activeRefs
                      || request.auth.uid in request.resource.data.activeRefs
                      || request.auth.uid in request.resource.data.waitingRoom
                      || request.auth.uid in resource.data.waitingRoom
                      || request.auth.uid in request.resource.data.notifyList
                      || request.auth.uid in resource.data.notifyList
                    );

      // Only the creator can delete a match
      allow delete: if request.auth != null
                    && request.auth.uid == resource.data.creatorId;

      // Participants subcollection — any authenticated user can read/write
      match /participants/{participantId} {
        allow read, write: if request.auth != null;
      }
    }
  }
}
